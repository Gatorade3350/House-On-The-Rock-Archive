        <section class="tour-section" id="tour3">
            <div class="tour-header">
                <h3>Tour 3 - Wonders & Collections</h3>
                <p>Includes the Organ Room, Circus Room, and various galleries</p>
            </div>
            <div class="tour-content">
                <ol class="machine-list" start="37">
                    <li class="machine-item">
